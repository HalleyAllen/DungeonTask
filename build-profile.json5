{
  "app": {
    "signingConfigs": [],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "6.0.2(22)",
        "compatibleSdkVersion": "6.0.2(22)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug",
      },
      {
        "name": "release"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    },
    // ===== common 通用层（跨项目可复用）=====
    {
      "name": "common.base",
      "srcPath": "./common/base"
    },
    {
      "name": "common.ui",
      "srcPath": "./common/ui"
    },
    {
      "name": "common.util",
      "srcPath": "./common/util"
    },
    // ===== core 项目特定层 =====
    {
      "name": "core.database",
      "srcPath": "./core/database"
    },
    {
      "name": "core.model",
      "srcPath": "./core/model"
    },
    {
      "name": "core.util",
      "srcPath": "./core/util"
    },
    // ===== feature 业务层 =====
    {
      "name": "feature.task",
      "srcPath": "./feature/task"
    },
    {
      "name": "feature.habit",
      "srcPath": "./feature/habit"
    },
    {
      "name": "feature.collection",
      "srcPath": "./feature/collection"
    },
    {
      "name": "feature.memo",
      "srcPath": "./feature/memo"
    },
    {
      "name": "feature.settings",
      "srcPath": "./feature/settings"
    }
  ]
}